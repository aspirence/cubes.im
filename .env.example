# Supabase — copy this file to .env.local and fill in your cloud project creds.
# Public (exposed to the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never exposed to the browser):
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# AI features (/api/ai/*) — server-only. Without a key the AI buttons return
# a friendly "not configured" error; everything else works.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-opus-4-8):
# ANTHROPIC_MODEL=

# Agent playground (/api/workflows/agents/run) — server-only OpenRouter access.
OPENROUTER_API_KEY=
# Optional model override (default: openrouter/auto):
# OPENROUTER_MODEL=

# --- Deployment mode -------------------------------------------------------
# Set to "true" ONLY on the hosted Cloud product to turn on paid plans + free-
# tier limits (also flip DB: `update platform_config set cloud_mode = true;`).
# Self-hosted installs leave this unset/false → fully unlimited, no billing UI.
NEXT_PUBLIC_CUBES_CLOUD=false
# Public base URL, used to build payment return URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Dodo Payments (server-only; test mode until keys are issued) -----------
DODO_PAYMENTS_API_KEY=
# "test_mode" or "live_mode"
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_WEBHOOK_SECRET=
# Product IDs created in the Dodo dashboard:
DODO_CLOUD_PRODUCT_ID=        # recurring subscription — Cloud plan
DODO_DEVICE_PRODUCT_ID=       # one-time $100 — AT-Cubes v0.1 device

